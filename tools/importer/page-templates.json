{
  "templates": [
    {
      "name": "landing-page",
      "urls": [
        "https://www.dicksmedia.com"
      ],
      "description": "Homepage landing page for DICK'S Media Network",
      "blocks": [
        {
          "name": "hero",
          "instances": [
            "section.page-section.has-background .fluid-engine"
          ]
        },
        {
          "name": "stats",
          "instances": [
            "section.page-section#counter .fluid-engine"
          ]
        },
        {
          "name": "columns",
          "instances": [
            "section.page-section:has(.fe-68402248b37fc210572c9bc0) .fluid-engine",
            "section.page-section:has(.fe-6840331be7a45b676cb53898) .fluid-engine",
            "section.page-section:has(.fe-684b206b6b5d0a2feb065be3) .fluid-engine"
          ]
        },
        {
          "name": "cards",
          "instances": [
            "section.page-section#solution-section .fluid-engine",
            "section.page-section#case-study-grid .user-items-list"
          ]
        },
        {
          "name": "accordion",
          "instances": [
            "section.page-section:has(.accordion-block) .fluid-engine"
          ]
        }
      ],
      "sections": [
        {
          "id": "section-1-hero",
          "name": "Hero",
          "selector": "section.page-section.has-background",
          "style": "dark",
          "blocks": [
            "hero"
          ],
          "defaultContent": []
        },
        {
          "id": "section-2-stats",
          "name": "Stats Counter",
