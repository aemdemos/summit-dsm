          "selector": "section.page-section:has(.fe-68402248b37fc210572c9bc0)",
          "style": "dark",
          "blocks": [
            "columns"
          ],
          "defaultContent": []
        },
        {
          "id": "section-4-solutions",
          "name": "Solutions Grid",
          "selector": "section.page-section#solution-section",
          "style": "dark",
          "blocks": [
            "cards"
          ],
          "defaultContent": []
        },
        {
          "id": "section-5-brand-partners",
          "name": "Brand Partners CTA",
          "selector": "section.page-section:has(.fe-6840331be7a45b676cb53898)",
